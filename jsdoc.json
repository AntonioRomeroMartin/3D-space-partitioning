{
  "source": {
    "include": ["src"],
    "includePattern": ".js$"
  },
  "opts": {
    "destination": "public/docs",
    "recurse": true,
    "readme": "README.md",
    "template": "node_modules/docdash"
  },
  "plugins": ["plugins/markdown"],
  "docdash": {
    "sort": true,
    "collapse": true,
    "removeQuotes": "none",
    "sectionOrder": ["Namespaces"],
    "scripts": ["docs-theme.css"],
    "menu": {}
  }
}
